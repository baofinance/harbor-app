NEXT_PUBLIC_PROJECT_ID=""

# --- RPC - required for Earn/Leverage locally (avoids CORS/429 from public RPC) ---
# Local: use proxy so the browser calls localhost and the server forwards to Alchemy (recommended).
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_USE_RPC_PROXY=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alternative (no proxy): NEXT_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- MegaETH markets (Genesis: USD-BTC, USD-wstETH etc.) ---
NEXT_PUBLIC_USE_MEGAETH=true
# Recommended (same pattern as mainnet): proxy + server-only URL so the key is not in the browser.
MEGAETH_RPC_URL=https://megaeth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# NEXT_PUBLIC_USE_RPC_PROXY=true  # (set above with MAINNET_RPC_URL — one flag covers both chains)
# Optional: MEGAETH_RPC_FALLBACK_URLS=https://rpc.megaeth.org
#
# Without proxy (dev only — key visible in DevTools): omit MEGAETH_RPC_URL and use:
# NEXT_PUBLIC_MEGAETH_RPC_URL=https://megaeth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Subgraph deploy (optional; for subgraph/deploy-production-no-prompt.sh)
# Get deploy key from https://thegraph.com/studio/ → your subgraph → Deploy key
# GRAPH_DEPLOY_KEY=""
# GRAPH_VERSION_LABEL="v0.1.2-metals-oracle"
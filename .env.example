NEXT_PUBLIC_PROJECT_ID=""

# --- RPC (Alchemy) - see docs/ALCHEMY_KEY_ROTATION_AND_SECURITY.md ---
# Production: use the proxy so the key never goes to the browser (recommended).
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# NEXT_PUBLIC_USE_RPC_PROXY=true
# NEXT_PUBLIC_APP_URL=https://app.harborfinance.io
# Optional (if not using proxy): NEXT_PUBLIC_MAINNET_RPC_URL=...

# Subgraph deploy (optional; for subgraph/deploy-production-no-prompt.sh)
# Get deploy key from https://thegraph.com/studio/ → your subgraph → Deploy key
# GRAPH_DEPLOY_KEY=""
# GRAPH_VERSION_LABEL="v0.1.2-metals-oracle"